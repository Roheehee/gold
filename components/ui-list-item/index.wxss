.ui-item {
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffdf7 100%);
  border: 1rpx solid rgba(244, 197, 66, 0.16);
}

.ui-item__top,
.ui-item__meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ui-item__title {
  font-size: 28rpx;
  font-weight: 700;
  color: #212838;
}

.ui-item__tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #fff6d6;
  color: #9b6c0b;
}

.ui-item__meta-row {
  margin-top: 12rpx;
}

.ui-item__meta,
.ui-item__desc {
  font-size: 24rpx;
  color: #8f7f58;
  line-height: 1.8;
}

.ui-item__value {
  font-size: 26rpx;
  font-weight: 700;
  color: #945f00;
}

.ui-item__desc {
  display: block;
  margin-top: 12rpx;
}
