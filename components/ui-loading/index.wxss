.ui-loading {
  padding: 48rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ui-loading__spinner {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(244, 197, 66, 0.26);
  border-top-color: #e1aa19;
  animation: spin 0.8s linear infinite;
}

.ui-loading__text {
  margin-top: 18rpx;
  font-size: 24rpx;
  color: #a18f67;
}

@keyframes spin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
