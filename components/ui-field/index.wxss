.ui-field {
  margin-bottom: 22rpx;
}

.ui-field__label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #806f48;
}

.ui-field__control {
  display: flex;
  align-items: center;
  min-height: 90rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(244, 197, 66, 0.2);
}

.ui-field__input {
  flex: 1;
  height: 90rpx;
  font-size: 28rpx;
  color: #1d2433;
}

.ui-field__unit {
  margin-left: 16rpx;
  font-size: 24rpx;
  color: #af9560;
}
