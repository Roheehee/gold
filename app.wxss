page {
  background:
    radial-gradient(circle at top right, rgba(244, 197, 66, 0.18), transparent 28%),
    linear-gradient(180deg, #fffefb 0%, #fffaf0 55%, #fffdf7 100%);
  color: #1d2433;
  font-family: "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
picker,
scroll-view {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 36rpx;
}

.shell {
  position: relative;
}

.shell::before {
  content: "";
  position: fixed;
  top: -200rpx;
  right: -140rpx;
  width: 480rpx;
  height: 480rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(244, 197, 66, 0.32) 0%, rgba(244, 197, 66, 0) 72%);
  pointer-events: none;
}

.hero {
  position: relative;
  overflow: hidden;
  padding: 36rpx 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fff7db 0%, #ffffff 62%, #fff3c1 100%);
  border: 1rpx solid rgba(226, 190, 75, 0.24);
  box-shadow: 0 22rpx 60rpx rgba(211, 172, 52, 0.12);
}

.hero::after {
  content: "";
  position: absolute;
  right: -64rpx;
  top: -72rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(244, 197, 66, 0.26), rgba(255, 255, 255, 0));
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(244, 197, 66, 0.3);
  color: #a67509;
  font-size: 22rpx;
}

.hero-title {
  display: block;
  margin-top: 18rpx;
  font-size: 44rpx;
  line-height: 1.28;
  font-weight: 700;
  color: #18212f;
}

.hero-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 25rpx;
  line-height: 1.8;
  color: #6d5d38;
}

.hero-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.meta-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #5f5132;
  font-size: 22rpx;
}

.section {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #18212f;
}

.section-desc {
  font-size: 22rpx;
  color: #8d7a4e;
}

.panel {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 28rpx;
  border: 1rpx solid rgba(242, 208, 111, 0.2);
  box-shadow: 0 18rpx 44rpx rgba(227, 188, 65, 0.1);
}

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.metric {
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #ffffff 0%, #fffaf0 100%);
  border: 1rpx solid rgba(244, 197, 66, 0.16);
}

.metric-label {
  display: block;
  font-size: 22rpx;
  color: #8c7a54;
}

.metric-value {
  display: block;
  margin-top: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #1d2433;
}

.metric-note {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #a69265;
}

.result-block {
  padding: 30rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #fffaf0 0%, #fff0ba 100%);
  border: 1rpx solid rgba(233, 191, 68, 0.22);
}

.result-caption {
  display: block;
  font-size: 24rpx;
  color: #94712a;
}

.result-amount {
  display: block;
  margin-top: 12rpx;
  font-size: 54rpx;
  font-weight: 700;
  color: #895f05;
}

.result-text {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.8;
  color: #866a2b;
}

.tag-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tag {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff7db;
  color: #946d0b;
  font-size: 22rpx;
  border: 1rpx solid rgba(244, 197, 66, 0.22);
}

.chart-card {
  padding: 26rpx;
}

.chart {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  height: 260rpx;
  margin-top: 28rpx;
}

.chart-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.chart-bar-wrap {
  width: 100%;
  height: 220rpx;
  padding: 0 10rpx;
  display: flex;
  align-items: flex-end;
}

.chart-bar {
  width: 100%;
  border-radius: 16rpx 16rpx 8rpx 8rpx;
  background: linear-gradient(180deg, #f8d868 0%, #ebb524 100%);
  box-shadow: 0 12rpx 28rpx rgba(235, 181, 36, 0.26);
}

.chart-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8a7952;
}

.chart-value {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #b18e33;
}

.split {
  height: 1rpx;
  background: linear-gradient(90deg, rgba(244, 197, 66, 0), rgba(244, 197, 66, 0.3), rgba(244, 197, 66, 0));
}

.inline-actions {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  flex-wrap: nowrap;
}

.inline-actions__item {
  flex: 0 1 260rpx;
  width: 260rpx;
  min-width: 0;
  max-width: calc(50% - 10rpx);
}

.muted {
  color: #9f8c62;
}

.danger {
  color: #d0472c;
}

.success {
  color: #17835d;
}
