.hero-content {
  margin-top: 28rpx;
}

.hero-section + .hero-section {
  margin-top: 28rpx;
}

.hero-section__title {
  display: block;
  color: #1d2433;
  font-size: 30rpx;
  font-weight: 700;
}

.hero-section__desc {
  display: block;
  margin-top: 12rpx;
  color: #8d7a4e;
  font-size: 22rpx;
  line-height: 1.7;
}

.hero-divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: linear-gradient(90deg, rgba(244, 197, 66, 0), rgba(244, 197, 66, 0.28), rgba(244, 197, 66, 0));
}

.hero-list-item {
  margin-top: 18rpx;
}

.asset-editor {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(244, 197, 66, 0.18);
}

.asset-editor__title {
  display: block;
  margin-bottom: 18rpx;
  color: #1d2433;
  font-size: 28rpx;
  font-weight: 700;
}

.asset-editor__actions {
  margin-top: 10rpx;
}

.history-clear-action {
  margin-top: 30rpx;
}

.section:last-child {
  padding-bottom: 32rpx;
}

.asset-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.asset-action {
  min-width: 108rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.asset-action--edit {
  background: #fff6d8;
  color: #8e6a0a;
}

.asset-action--delete {
  background: #fff0eb;
  color: #d04f2c;
}
