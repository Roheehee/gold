.section:last-child {
  padding-bottom: 32rpx;
}

.asset-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.asset-action {
  min-width: 108rpx;
  height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.asset-action--edit {
  background: #fff6d8;
  color: #8e6a0a;
}

.asset-action--delete {
  background: #fff0eb;
  color: #d04f2c;
}
