<view class="page shell">
  <view class="hero">
    <text class="hero-title">总资产与历史记录</text>
    <view class="hero-meta">
      <text class="meta-chip">资产条目 {{assets.length}}</text>
      <text class="meta-chip">历史记录 {{history.length}}</text>
      <text class="meta-chip">总估值 ¥{{totalValue}}</text>
    </view>

    <view class="hero-content">
      <view class="hero-section">
        <text class="hero-section__title">资产台账</text>
        <block wx:if="{{assets.length}}">
          <block wx:for="{{assets}}" wx:key="id">
            <view class="hero-list-item">
              <ui-list-item title="{{item.name}}" tag="{{item.typeText}}" meta="{{item.spec}}" value="¥ {{item.estimatedValue}}" desc="{{item.remark}}">
                <view class="asset-actions">
                  <view class="asset-action asset-action--edit" data-id="{{item.id}}" bindtap="startEditAsset">编辑</view>
                  <view class="asset-action asset-action--delete" data-id="{{item.id}}" bindtap="removeAsset">删除</view>
                </view>
              </ui-list-item>
            </view>
          </block>
        </block>
        <ui-empty wx:else title="暂无资产台账" desc="可以从首页计算结果中一键加入资产台账。" />

        <view wx:if="{{editingAssetId}}" class="asset-editor">
          <text class="asset-editor__title">编辑资产</text>
          <ui-field label="资产名称" value="{{assetForm.name}}" placeholder="请输入资产名称" data-field="name" bind:input="handleAssetFormInput" />
          <ui-field label="资产规格" value="{{assetForm.spec}}" placeholder="请输入规格" data-field="spec" bind:input="handleAssetFormInput" />
          <ui-field label="估值金额" value="{{assetForm.estimatedValue}}" placeholder="请输入估值金额" type="digit" data-field="estimatedValue" bind:input="handleAssetFormInput" />
          <ui-field label="备注" value="{{assetForm.remark}}" placeholder="请输入备注" data-field="remark" bind:input="handleAssetFormInput" />
          <view class="inline-actions asset-editor__actions">
            <view class="inline-actions__item">
              <ui-button text="取消" type="secondary" block="{{true}}" bind:tap="cancelEditAsset" />
            </view>
            <view class="inline-actions__item">
              <ui-button text="保存修改" type="primary" block="{{true}}" bind:tap="saveAssetEdit" />
            </view>
          </view>
        </view>
      </view>

      <view class="hero-divider"></view>

      <view class="hero-section">
        <text class="hero-section__title">历史计算记录</text>
        <block wx:if="{{history.length}}">
          <block wx:for="{{history}}" wx:key="id">
            <view class="hero-list-item">
              <ui-list-item title="{{item.title}}" tag="{{item.type === 'gold' ? '黄金' : item.type === 'diamond' ? '钻石' : '组合'}}" meta="{{item.spec}}" value="¥ {{item.estimatedValue}}" desc="保存时间：{{item.createdAt}}" />
            </view>
          </block>
          <view class="history-clear-action">
            <ui-button text="清空历史记录" type="secondary" block="{{true}}" bind:tap="clearHistory" />
          </view>
        </block>
        <ui-empty wx:else title="暂无历史记录" desc="在首页点击保存记录后，这里会自动展示最近的估值历史。" />
      </view>
    </view>
  </view>
</view>
