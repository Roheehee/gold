<view class="page shell">
  <view class="section">
    <view class="calculator-tabs">
      <block wx:for="{{calculatorTabs}}" wx:key="key">
        <view class="calculator-tab {{currentTab === item.key ? 'calculator-tab--active' : ''}}" data-tab="{{item.key}}" bindtap="handleTabChange">
          <text class="calculator-tab__text">{{item.label}}</text>
        </view>
      </block>
    </view>
  </view>

  <view class="section" wx:if="{{currentTab === 'gold'}}">
    <ui-card title="黄金估值参数">
      <view class="ui-field">
        <text class="ui-field__label">黄金类型</text>
        <picker mode="selector" range="{{goldKOptions}}" range-key="label" value="{{goldKIndex}}" bindchange="handleGoldKChange">
          <view class="ui-field__control">
            <text class="ui-field__input">{{goldKOptions[goldKIndex].label}}</text>
          </view>
        </picker>
      </view>
      <ui-field label="黄金克重" value="{{goldWeight}}" placeholder="例如 12.5" type="digit" unit="g" bind:input="handleGoldWeightInput" />
      <view class="inline-actions">
        <button class="action-btn action-btn--secondary" bindtap="saveRecord">保存记录</button>
        <button class="action-btn action-btn--primary" bindtap="addToAssets">加入资产台账</button>
      </view>
    </ui-card>
  </view>

  <view class="section" wx:if="{{currentTab === 'gold'}}">
    <ui-card title="黄金估值结果">
      <view class="result-block">
        <text class="result-caption">黄金参考估值</text>
        <text class="result-amount">¥ {{goldEstimatedValue}}</text>
      </view>
      <view class="tag-row" style="margin-top: 20rpx;">
        <text class="tag">{{goldRecordLabel}}</text>
        <text class="tag">金价更新：{{market.updatedAt}}</text>
      </view>
    </ui-card>
  </view>

  <view class="section" wx:if="{{currentTab === 'diamond' || currentTab === 'combo'}}">
    <ui-card title="钻石参数">
      <ui-field label="钻石重量" value="{{diamondCarat}}" placeholder="例如 1.0" type="digit" unit="ct" bind:input="handleDiamondCaratInput" />

      <view class="ui-field">
        <text class="ui-field__label">颜色</text>
        <picker mode="selector" range="{{diamondColorOptions}}" range-key="label" value="{{diamondColorIndex}}" bindchange="handleDiamondColorChange">
          <view class="ui-field__control">
            <text class="ui-field__input">{{diamondColorOptions[diamondColorIndex].label}}</text>
          </view>
        </picker>
      </view>

      <view class="ui-field">
        <text class="ui-field__label">净度</text>
        <picker mode="selector" range="{{diamondClarityOptions}}" range-key="label" value="{{diamondClarityIndex}}" bindchange="handleDiamondClarityChange">
          <view class="ui-field__control">
            <text class="ui-field__input">{{diamondClarityOptions[diamondClarityIndex].label}}</text>
          </view>
        </picker>
      </view>

      <view class="ui-field">
        <text class="ui-field__label">切工</text>
        <picker mode="selector" range="{{diamondCutOptions}}" range-key="label" value="{{diamondCutIndex}}" bindchange="handleDiamondCutChange">
          <view class="ui-field__control">
            <text class="ui-field__input">{{diamondCutOptions[diamondCutIndex].label}}</text>
          </view>
        </picker>
      </view>
    </ui-card>
  </view>

  <view class="section" wx:if="{{currentTab === 'diamond'}}">
    <ui-card title="钻石估值结果" desc="市场参考价适合比价，回收价区间更接近日常流通。">
      <view class="result-block">
        <text class="result-caption">市场参考价</text>
        <text class="result-amount">¥ {{diamondEstimatedValue}}</text>
        <text class="result-text">{{diamondResultDescription}}</text>
      </view>
      <view class="diamond-range-card">
        <text class="diamond-range-card__label">回收参考区间</text>
        <text class="diamond-range-card__value">¥ {{diamondRecycleRange}}</text>
      </view>
      <view class="tag-row" style="margin-top: 20rpx;">
        <text class="tag">{{diamondRecordLabel}}</text>
      </view>
      <view class="inline-actions action-space">
        <button class="action-btn action-btn--secondary" bindtap="saveRecord">保存记录</button>
        <button class="action-btn action-btn--primary" bindtap="addToAssets">加入资产台账</button>
      </view>
    </ui-card>
  </view>

  <view class="section" wx:if="{{currentTab === 'combo'}}">
    <ui-card title="贵金属参数" desc="组合估值支持黄金不同 K 金、铂金和银。">
      <view class="ui-field">
        <text class="ui-field__label">贵金属类型</text>
        <picker mode="selector" range="{{comboMetalOptions}}" range-key="label" value="{{comboMetalIndex}}" bindchange="handleComboMetalChange">
          <view class="ui-field__control">
            <text class="ui-field__input">{{comboMetalOptions[comboMetalIndex].label}}</text>
          </view>
        </picker>
      </view>
      <ui-field label="贵金属重量" value="{{comboMetalWeight}}" placeholder="例如 10" type="digit" unit="g" bind:input="handleComboGoldWeightInput" />
    </ui-card>
  </view>

  <view class="section" wx:if="{{currentTab === 'combo'}}">
    <ui-card title="组合估值结果" desc="组合模式会同时给出市场参考总价和回收参考区间。">
      <view class="result-block">
        <text class="result-caption">组合市场参考价</text>
        <text class="result-amount">¥ {{comboEstimatedValue}}</text>
        <text class="result-text">{{comboResultDescription}}</text>
      </view>
      <view class="diamond-range-card">
        <text class="diamond-range-card__label">组合回收参考区间</text>
        <text class="diamond-range-card__value">¥ {{comboRecycleRange}}</text>
      </view>
      <view class="tag-row" style="margin-top: 20rpx;">
        <text class="tag">{{comboRecordLabel}}</text>
      </view>
      <view class="inline-actions action-space">
        <button class="action-btn action-btn--secondary" bindtap="saveRecord">保存记录</button>
        <button class="action-btn action-btn--primary" bindtap="addToAssets">加入资产台账</button>
      </view>
    </ui-card>
  </view>
</view>
