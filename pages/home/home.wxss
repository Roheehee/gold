.page-top {
  margin-top: 4rpx;
}

.calculator-tabs {
  display: flex;
  gap: 16rpx;
}

.calculator-tab {
  flex: 1;
  min-height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid rgba(244, 197, 66, 0.18);
}

.calculator-tab--active {
  background: linear-gradient(135deg, #f7d462 0%, #efba28 100%);
  box-shadow: 0 12rpx 28rpx rgba(239, 186, 40, 0.18);
}

.calculator-tab__text {
  font-size: 27rpx;
  font-weight: 700;
  color: #7a631f;
}

.calculator-tab--active .calculator-tab__text {
  color: #fff;
}

.ui-field {
  margin-bottom: 22rpx;
}

.ui-field__label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #806f48;
}

.ui-field__control {
  display: flex;
  align-items: center;
  min-height: 90rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(244, 197, 66, 0.2);
}

.ui-field__input {
  flex: 1;
  font-size: 28rpx;
  color: #1d2433;
}

.diamond-range-card {
  margin-top: 18rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #fff9e9;
  border: 1rpx solid rgba(244, 197, 66, 0.18);
}

.diamond-range-card__label {
  display: block;
  font-size: 23rpx;
  color: #8f7741;
}

.diamond-range-card__value {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #8f6200;
}

.action-space {
  margin-top: 20rpx;
}
