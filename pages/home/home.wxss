.calculator-tabs {
  display: flex;
  gap: 14rpx;
  padding: 10rpx;
  border-radius: 30rpx;
  background: rgba(255, 251, 241, 0.92);
  border: 1rpx solid rgba(244, 197, 66, 0.14);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.calculator-tab {
  flex: 1;
  min-height: 92rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 250, 239, 0.96) 100%);
  border: 1rpx solid rgba(244, 197, 66, 0.12);
  box-shadow: 0 10rpx 22rpx rgba(232, 194, 81, 0.08);
}

.calculator-tab--active {
  background: linear-gradient(135deg, #ffd861 0%, #f5c12f 54%, #eca90d 100%);
  border-color: rgba(236, 169, 13, 0.24);
  box-shadow: 0 16rpx 34rpx rgba(239, 186, 40, 0.26);
}

.calculator-tab__text {
  font-size: 26rpx;
  font-weight: 700;
  color: #765d18;
  letter-spacing: 1rpx;
}

.calculator-tab--active .calculator-tab__text {
  color: #fff;
}

.ui-field {
  margin-bottom: 22rpx;
}

.ui-field__label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: #806f48;
}

.ui-field__control {
  display: flex;
  align-items: center;
  min-height: 90rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #fffdf8;
  border: 1rpx solid rgba(244, 197, 66, 0.2);
}

.ui-field__input {
  flex: 1;
  font-size: 28rpx;
  color: #1d2433;
}

.diamond-range-card {
  margin-top: 18rpx;
  padding: 24rpx 26rpx;
  border-radius: 24rpx;
  background: #fff9e9;
  border: 1rpx solid rgba(244, 197, 66, 0.18);
}

.diamond-range-card__label {
  display: block;
  font-size: 23rpx;
  color: #8f7741;
}

.diamond-range-card__value {
  display: block;
  margin-top: 10rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #8f6200;
}

.action-space {
  margin-top: 20rpx;
}

.inline-actions {
  justify-content: center;
}

.action-btn {
  width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  border: none;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  box-shadow: 0 8rpx 18rpx rgba(31, 35, 41, 0.05);
}

.action-btn::after {
  border: none;
}

.action-btn--primary {
  background: linear-gradient(135deg, #ffd75f 0%, #f5bf2a 58%, #e4a10b 100%);
  color: #fff;
  box-shadow: 0 12rpx 24rpx rgba(219, 170, 28, 0.22);
}

.action-btn--secondary {
  background: linear-gradient(180deg, #fff8df 0%, #ffefb8 100%);
  color: #936d08;
  border: 1rpx solid rgba(235, 190, 47, 0.18);
}
